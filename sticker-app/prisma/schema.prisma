// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../app/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector, pgcrypto]
}

// ── AUTH.JS MODELS ────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  role          String    @default("user")
  // role: "user" | "admin"

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Sticker {
  // ── IDENTITY ──────────────────────────────────────────────────────────
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug            String   @unique
  // human-readable unique ID e.g. "angry-rajni-001" for debugging & URLs

  // ── FILE ──────────────────────────────────────────────────────────────
  cloudinaryUrl   String   @map("cloudinary_url")
  thumbnailUrl    String   @map("thumbnail_url")
  // Cloudinary auto-generates thumbnail, store it separately for fast loading
  type            String
  fileSizeKb      Int?     @map("file_size_kb")
  widthPx         Int?     @map("width_px")
  heightPx        Int?     @map("height_px")
  durationMs      Int?     @map("duration_ms")
  // duration only for gif/video stickers, null for static images

  // ── CONTENT & LANGUAGE ────────────────────────────────────────────────
  title           String
  // human-readable name e.g. "Rajni Sunglasses Toss"
  description     String?
  // one line describing what's happening in the sticker
  ocrText         String?  @map("ocr_text")
  // raw text extracted from the sticker image if any text overlay exists
  languages       String[] @default([])
  // e.g. ['kannada','english'] — used for language-filtered rooms
  hasTextOverlay  Boolean  @default(false) @map("has_text_overlay")
  // quick flag: does this sticker have text on it?

  // ── CATEGORISATION ────────────────────────────────────────────────────
  category        String
  // primary bucket e.g. 'bollywood' | 'cricket' | 'anime' | 'meme' |
  //   'regional_kannada' | 'regional_tamil' | 'animals' | 'politics' |
  //   'web_culture' | 'devotional' | 'sports' | 'TV_shows'
  subCategory     String?  @map("sub_category")
  // more specific e.g. category='bollywood' sub_category='rajnikanth'
  sourceName      String?  @map("source_name")
  // where it came from e.g. 'tenor_scrape' | 'reddit_scrape' |
  //   'telegram_pack_xyz' | 'manual_upload'
  originalUrl     String?  @map("original_url")
  // original source URL if scraped, for attribution/audit trail

  // ── EMOTION & MOOD ────────────────────────────────────────────────────
  dominantEmotion String?  @map("dominant_emotion")
  // single strongest emotion: 'angry'|'happy'|'sad'|'shocked'|
  //   'disgusted'|'fearful'|'neutral'|'sarcastic'|'confused'
  emotionScores   Json     @default("{}") @map("emotion_scores")
  // full breakdown: {"angry":87.3,"happy":4.1,"neutral":8.6}
  // stored as JSONB so you can query: emotion_scores->>'angry' > '80'
  energyLevel     String?  @map("energy_level")
  // low = subtle/quiet, chaotic = extreme reaction
  tone            String[] @default([])
  // multiple tones can coexist: ['sarcastic','dramatic'] or ['wholesome','funny']

  // ── CONTEXT TAGS ──────────────────────────────────────────────────────
  tags            String[] @default([])
  // general searchable tags: ['betrayal','food','friendship','relatable']
  scenarioFit     String[] @default([]) @map("scenario_fit")
  // what type of scenarios this sticker works best for
  // e.g. ['exam_failure','late_friend','power_cut','monday_morning']
  // manually curated during your verification step — this is GOLD for scoring
  useCase         String?  @map("use_case")
  // this single field is extremely powerful for escalation chain logic
  // the game engine can check: "is this sticker an escalation type?"

  // ── AI / VECTOR ───────────────────────────────────────────────────────
  clipEmbedding   Unsupported("vector(512)")? @map("clip_embedding")
  // OpenAI CLIP ViT-B/32 embedding — used for cosine similarity scoring
  clipTags        String[] @default([]) @map("clip_tags")
  // auto-generated tags from CLIP zero-shot classification
  // separate from manual tags so you can compare/audit both

  // ── MODERATION ────────────────────────────────────────────────────────
  phash           String?  @unique
  // perceptual hash for duplicate detection and blocklist matching
  isLive          Boolean  @default(false) @map("is_live")
  // only true after manual verification is complete
  isNsfw          Boolean  @default(false) @map("is_nsfw")
  nsfwScore       Float    @default(0.0) @map("nsfw_score")
  // Falconsai score 0.0 (safe) to 1.0 (explicit)
  moderationNotes String?  @map("moderation_notes")
  // moderator can leave a note during manual review
  verifiedBy      String?  @map("verified_by")
  // moderator name/ID who approved this sticker
  verifiedAt      DateTime? @map("verified_at")
  reportCount     Int      @default(0) @map("report_count")
  // increments when users report this sticker in-game
  isFlagged       Boolean  @default(false) @map("is_flagged")
  // auto-set true when report_count crosses threshold

  // ── SCORING WEIGHTS (manually set during verification) ────────────────
  baseScoreWeight Float    @default(1.0) @map("base_score_weight")
  // multiplier applied to this sticker's score when it wins a round
  // rare/legendary stickers can have higher base weight e.g. 1.5
  rarity          String   @default("common")
  // rarity affects visual presentation in-game and base_score_weight
  // future: legendary stickers show special reveal animation

  // ── PERFORMANCE STATS (updated over time) ────────────────────────────
  playCount       Int      @default(0) @map("play_count")
  // how many times this sticker has been played in any game
  winCount        Int      @default(0) @map("win_count")
  // how many rounds this sticker won (most votes)
  voteCount       Int      @default(0) @map("vote_count")
  // total votes received across all games
  avgClipScore    Float    @default(0.0) @map("avg_clip_score")
  // running average of CLIP similarity score when this sticker was played
  // over time tells you: is this sticker genuinely contextually good?
  avgVoteScore    Float    @default(0.0) @map("avg_vote_score")
  // running average of votes received per round played
  // over time tells you: do players actually like this sticker?
  hypeCount       Int      @default(0) @map("hype_count")
  // total 🔥 reactions received across all games
  timesFavourited Int      @default(0) @map("times_favourited")
  // how many players have hearted this sticker

  // ── TIMESTAMPS ────────────────────────────────────────────────────────
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at")

  @@map("stickers")
}
